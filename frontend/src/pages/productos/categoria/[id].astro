---
import Layout from "../../../layouts/Layout.astro";

const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3001";
const { id } = Astro.params;

const res = await fetch(`${API_URL}/api/productos/categoria/${id}`);
if (!res.ok) return Astro.redirect("/productos");

const { productos, categoria } = await res.json();
---

<Layout title={`Categoría: ${categoria.nombre}`}>
  <a href="/productos" style="color:#1d4ed8;font-size:0.9rem;">← Volver a productos</a>
  <h1 style="font-size:1.75rem;font-weight:700;margin:1rem 0 1.5rem;">{categoria.nombre}</h1>

  {productos.length === 0 ? (
    <div class="card" style="text-align:center;color:#64748b;">No hay productos en esta categoría.</div>
  ) : (
    <div class="grid-productos">
      {productos.map((p: any) => (
        <a href={`/productos/${p.id}`} style="text-decoration:none;color:inherit;">
          <div class="producto-card">
            <img src={p.imagen || "https://via.placeholder.com/300x180?text=Producto"} alt={p.nombre} />
            <div class="info">
              <div class="nombre">{p.nombre}</div>
              <div class="precio">${Number(p.precio_unitario).toFixed(2)}</div>
            </div>
          </div>
        </a>
      ))}
    </div>
  )}
</Layout>
