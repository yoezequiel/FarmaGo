---
import Layout from "../layouts/Layout.astro";

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");
if (user.role === "cliente") return Astro.redirect("/productos");
if (user.role !== "farmacia") return Astro.redirect("/");

const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3001";
const token = Astro.cookies.get("token")?.value;

const [ventasRes, invRes] = await Promise.all([
  fetch(`${API_URL}/api/ventas`, { headers: { Cookie: `token=${token}` } }),
  fetch(`${API_URL}/api/inventario`, { headers: { Cookie: `token=${token}` } }),
]);
const ventas = ventasRes.ok ? await ventasRes.json() : [];
const inventario = invRes.ok ? await invRes.json() : [];
const totalVentas = ventas.reduce((acc: number, v: any) => acc + Number(v.total), 0);
---

<Layout title="Panel de farmacia">
  <h1 style="font-size:1.75rem;font-weight:700;margin-bottom:1.5rem;">Panel de Farmacia</h1>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1rem;margin-bottom:2rem;">
    <div class="card" style="text-align:center;">
      <div style="font-size:1.75rem;font-weight:800;color:#1d4ed8;">{inventario.length}</div>
      <div style="font-size:0.875rem;color:#64748b;margin-top:0.25rem;">Productos</div>
    </div>
    <div class="card" style="text-align:center;">
      <div style="font-size:1.75rem;font-weight:800;color:#16a34a;">${totalVentas.toFixed(2)}</div>
      <div style="font-size:0.875rem;color:#64748b;margin-top:0.25rem;">Total vendido</div>
    </div>
    <div class="card" style="text-align:center;">
      <div style="font-size:1.75rem;font-weight:800;color:#7c3aed;">{ventas.length}</div>
      <div style="font-size:0.875rem;color:#64748b;margin-top:0.25rem;">Ventas</div>
    </div>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1.5rem;">
    <a href="/inventario" style="text-decoration:none;">
      <div class="card" style="text-align:center;cursor:pointer;">
        <div style="font-size:2.5rem;margin-bottom:0.5rem;">📦</div>
        <h3 style="font-weight:600;">Inventario</h3>
        <p style="color:#64748b;font-size:0.875rem;margin-top:0.25rem;">Gestionar stock</p>
      </div>
    </a>
    <a href="/productos/agregar" style="text-decoration:none;">
      <div class="card" style="text-align:center;cursor:pointer;">
        <div style="font-size:2.5rem;margin-bottom:0.5rem;">➕</div>
        <h3 style="font-weight:600;">Agregar Producto</h3>
        <p style="color:#64748b;font-size:0.875rem;margin-top:0.25rem;">Nuevo producto</p>
      </div>
    </a>
    <a href="/ventas" style="text-decoration:none;">
      <div class="card" style="text-align:center;cursor:pointer;">
        <div style="font-size:2.5rem;margin-bottom:0.5rem;">💰</div>
        <h3 style="font-weight:600;">Ventas</h3>
        <p style="color:#64748b;font-size:0.875rem;margin-top:0.25rem;">Historial de ventas</p>
      </div>
    </a>
    <a href="/perfil" style="text-decoration:none;">
      <div class="card" style="text-align:center;cursor:pointer;">
        <div style="font-size:2.5rem;margin-bottom:0.5rem;">👤</div>
        <h3 style="font-weight:600;">Perfil</h3>
        <p style="color:#64748b;font-size:0.875rem;margin-top:0.25rem;">Ver y editar perfil</p>
      </div>
    </a>
  </div>
</Layout>
