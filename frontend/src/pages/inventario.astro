---
import Layout from "../layouts/Layout.astro";

const user = Astro.locals.user;
if (!user || user.role !== "farmacia") return Astro.redirect("/login");

const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3001";
const token = Astro.cookies.get("token")?.value;

let success = "";
let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const ids = form.getAll("id_producto");
  const cantidades = form.getAll("cantidad");
  const inventario = ids.map((id, i) => ({ id_producto: id, cantidad: cantidades[i] }));

  const res = await fetch(`${API_URL}/api/inventario`, {
    method: "POST",
    headers: { "Content-Type": "application/json", Cookie: `token=${token}` },
    body: JSON.stringify({ inventario }),
  });
  if (res.ok) success = "Inventario actualizado correctamente";
  else error = "Error al actualizar inventario";
}

const res = await fetch(`${API_URL}/api/inventario`, {
  headers: { Cookie: `token=${token}` },
});
const inventario = await res.json();
---

<Layout title="Inventario">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;flex-wrap:wrap;gap:1rem;">
    <h1 style="font-size:1.75rem;font-weight:700;">Inventario</h1>
    <a href="/productos/agregar" class="btn btn-primary">+ Agregar producto</a>
  </div>

  {success && <div class="alert-success">{success}</div>}
  {error && <div class="alert-error">{error}</div>}

  {inventario.length === 0 ? (
    <div class="card" style="text-align:center;color:#64748b;padding:3rem;">
      No tienes productos aún. <a href="/productos/agregar">Agregar uno</a>
    </div>
  ) : (
    <form method="POST">
      <div class="card" style="padding:0;overflow:hidden;">
        <table>
          <thead>
            <tr>
              <th>Producto</th>
              <th style="text-align:right;">Precio</th>
              <th style="text-align:center;">Stock total</th>
              <th style="text-align:center;">Disponible</th>
              <th style="text-align:center;">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {inventario.map((item: any) => (
              <tr>
                <td style="font-weight:500;">{item.nombre}</td>
                <td style="text-align:right;">${Number(item.precio_unitario).toFixed(2)}</td>
                <td style="text-align:center;">
                  <span style={`color:${Number(item.cantidad) === 0 ? "#dc2626" : "#1e293b"};font-weight:${Number(item.cantidad) === 0 ? "600" : "400"};`}>
                    {item.cantidad}
                  </span>
                </td>
                <td style="text-align:center;">
                  <input type="hidden" name="id_producto" value={item.id} />
                  <input type="number" name="cantidad" value={item.cantidad_disponible} min="0"
                    style="width:80px;padding:0.25rem 0.5rem;border:1px solid #cbd5e1;border-radius:4px;text-align:center;" />
                </td>
                <td style="text-align:center;">
                  <div style="display:flex;gap:0.5rem;justify-content:center;">
                    <a href={`/productos/editar/${item.id}`} class="btn btn-secondary" style="padding:0.25rem 0.6rem;font-size:0.8rem;">Editar</a>
                    <form method="POST" action={`/api/productos/eliminar/${item.id}`} style="display:inline">
                      <button type="submit" class="btn btn-danger" style="padding:0.25rem 0.6rem;font-size:0.8rem;"
                        onclick="return confirm('¿Eliminar este producto permanentemente?')">Eliminar</button>
                    </form>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <button type="submit" class="btn btn-primary" style="margin-top:1rem;">Actualizar disponibilidad</button>
    </form>
  )}
</Layout>
