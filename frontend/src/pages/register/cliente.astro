---
import Layout from "../../layouts/Layout.astro";

if (Astro.locals.user) return Astro.redirect("/dashboard");

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const body = Object.fromEntries(form.entries());

  const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3001";
  const res = await fetch(`${API_URL}/api/auth/register/cliente`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(body),
  });

  if (res.ok) return Astro.redirect("/login");
  const data = await res.json();
  error = data.error || "Error al registrarse";
}
---

<Layout title="Registro de cliente">
  <div style="max-width:500px;margin:2rem auto;">
    <div class="card">
      <h2 style="margin-bottom:1.5rem;font-size:1.5rem;font-weight:700;">Registro de cliente</h2>
      {error && <div class="alert-error">{error}</div>}
      <form method="POST">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div class="form-group">
            <label>Nombre</label>
            <input type="text" name="nombre" required />
          </div>
          <div class="form-group">
            <label>Apellido</label>
            <input type="text" name="apellido" required />
          </div>
        </div>
        <div class="form-group">
          <label>Correo electrónico</label>
          <input type="email" name="correo_electronico" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label>Nombre de usuario</label>
          <input type="text" name="nombre_usuario" required autocomplete="username" />
        </div>
        <div class="form-group">
          <label>Contraseña</label>
          <input type="password" name="contrasena" required minlength="8" autocomplete="new-password" />
        </div>
        <div class="form-group">
          <label>Dirección</label>
          <input type="text" name="direccion" />
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div class="form-group">
            <label>Provincia</label>
            <input type="text" name="provincia" />
          </div>
          <div class="form-group">
            <label>Localidad</label>
            <input type="text" name="localidad" />
          </div>
        </div>
        <div class="form-group">
          <label>Teléfono</label>
          <input type="tel" name="numero_telefono" />
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;">Crear cuenta</button>
      </form>
      <p style="margin-top:1rem;text-align:center;font-size:0.9rem;">
        ¿Sos farmacia? <a href="/register/farmacia">Registrate aquí</a> · <a href="/login">Ya tengo cuenta</a>
      </p>
    </div>
  </div>
</Layout>
