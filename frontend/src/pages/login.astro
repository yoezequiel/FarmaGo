---
import Layout from "../layouts/Layout.astro";

if (Astro.locals.user) return Astro.redirect("/dashboard");

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const body = {
    correo_electronico: form.get("correo_electronico"),
    contrasena: form.get("contrasena"),
  };

  const API_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3001";
  const res = await fetch(`${API_URL}/api/auth/login`, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(body),
  });

  if (res.ok) {
    const setCookie = res.headers.get("set-cookie");
    if (setCookie) {
      const match = setCookie.match(/token=([^;]+)/);
      if (match) {
        Astro.cookies.set("token", match[1], {
          httpOnly: true,
          sameSite: "lax",
          maxAge: 7 * 24 * 60 * 60,
          path: "/",
        });
      }
    }
    const data = await res.json();
    return Astro.redirect(data.role === "farmacia" ? "/dashboard" : "/productos");
  } else {
    const data = await res.json();
    error = data.error || "Error al iniciar sesión";
  }
}
---

<Layout title="Iniciar sesión">
  <div style="max-width:400px;margin:2rem auto;">
    <div class="card">
      <h2 style="margin-bottom:1.5rem;font-size:1.5rem;font-weight:700;">Iniciar sesión</h2>
      {error && <div class="alert-error">{error}</div>}
      <form method="POST">
        <div class="form-group">
          <label>Correo electrónico</label>
          <input type="email" name="correo_electronico" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label>Contraseña</label>
          <input type="password" name="contrasena" required autocomplete="current-password" />
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;">Ingresar</button>
      </form>
      <p style="margin-top:1rem;text-align:center;font-size:0.9rem;">
        ¿No tenés cuenta? <a href="/register/cliente">Cliente</a> · <a href="/register/farmacia">Farmacia</a>
      </p>
    </div>
  </div>
</Layout>
